---
/**
 * BrushStrokeW —— 毛笔书法 W
 * ============================================================
 * 实现：SVG fill path（不是 stroke），从左到右 clip-path 揭开
 *   - 真·提按：path 本身是变宽的（起笔粗 → 中段提 → 收锋甩尾）
 *   - 真·飞白：path 尾端收锋自然尖细
 *   - 揭开/擦除：CSS 变量 --reveal 驱动 clip-path inset
 *
 * State：
 *   - 'static'  默认：完全显示，无动画
 *   - 'reveal'  正向揭开（运笔），630ms
 *   - 'erase'   反向擦除（倒放），460ms
 *
 * Path 说明：
 *   viewBox 72×64，字形占据 4-68 的横向空间
 *   W 的四笔一气呵成：
 *     起笔：左上 (6,10) 粗重向下斜 → 第一谷底 (20,54)
 *     第一峰：上扬到 (30,22)（比边峰低，形成 W 节奏）
 *     第二谷：(42,54)
 *     收锋：右上 (66,10)，尾端微细向上甩
 *   使用闭合多边形而非 stroke，允许粗细变化
 */

interface Props {
  state?: 'static' | 'reveal' | 'erase';
  className?: string;
  ariaLabel?: string;
}

const {
  state = 'static',
  className = '',
  ariaLabel = 'W',
} = Astro.props;

const stateClass =
  state === 'reveal' ? 'is-writing' :
  state === 'erase'  ? 'is-erasing' :
                       'is-static';
---

<svg
  class:list={['brush-w', stateClass, className]}
  viewBox="0 0 72 64"
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label={ariaLabel}
  fill="currentColor"
  stroke="none"
>
  {/*
    毛笔 W 字形（fill path）
    几何思路：
      - 每一笔是一个"梭形"多边形
      - 四笔头尾相接，整体形成 W
      - 起笔/收锋端做尖锐处理（模拟毛笔飞白）
      - 谷底做圆角过渡（模拟墨迹停顿变粗）
  */}
  <path d="
    M 4 8
    L 10 6
    L 20 52
    L 24 58
    L 28 56
    L 33 26
    L 35 20
    L 37 20
    L 39 26
    L 44 56
    L 48 58
    L 52 52
    L 62 6
    L 68 8
    L 66 12
    L 56 56
    L 52 62
    L 46 62
    L 42 58
    L 37 32
    L 36 30
    L 35 30
    L 34 32
    L 30 58
    L 26 62
    L 20 62
    L 16 56
    L 6 12
    Z
  " />
</svg>
