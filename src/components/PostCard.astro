---
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, date, summary, tags } = post.data;

const dateLabel = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(date);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class="group py-5 border-b border-line last:border-b-0">
  <a href={`${base}/blog/${post.slug}`} class="block">
    <div class="flex items-baseline justify-between gap-4">
      <h3 class="font-sans text-lg sm:text-xl font-black text-ink-900 group-hover:text-brand transition-colors">
        {title}
      </h3>
      <time class="shrink-0 font-mono text-xs text-ink-500 tabular-nums">{dateLabel}</time>
    </div>
    <p class="mt-1.5 text-ink-700 text-sm sm:text-base leading-relaxed line-clamp-2">
      {summary}
    </p>
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((t) => <Tag label={t} />)}
      </div>
    )}
  </a>
</article>
