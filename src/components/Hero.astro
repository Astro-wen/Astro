---
import { SITE } from '@/lib/site';
---

{/*
  Hero —— 孤星×现代主义风格
  -------------------------------------------
  1. 编号胶条（border-left 粗色条 · 孤星系统消息做法）
  2. 主标题：Geist 900 + 紧字距 + RGB 错位阴影（Lonetrail 海报风）
  3. 姓名打字：Aaron Wen → 温思源 → AstroW（W 为 SVG 手写）
  4. 左侧竖色条装饰（Lonetrail 四色条）
  5. 双语：.i18n-en / .i18n-zh 由 html[data-lang] 控制
*/}

<section class="relative container-wide pt-24 sm:pt-32 pb-20 sm:pb-28" id="hero-root">

  {/* 右上角三原色装饰线（不遮挡，只作为海报感角标） */}
  <div
    class="hidden md:flex absolute right-6 lg:right-10 top-28 sm:top-32 flex-col items-end gap-2 pointer-events-none select-none"
    aria-hidden="true"
  >
    <span class="block h-[2px] w-24 bg-vhs-cyan"></span>
    <span class="block h-[2px] w-16 bg-vhs-yellow"></span>
    <span class="block h-[2px] w-10 bg-vhs-red"></span>
  </div>

  {/* 顶部编号胶条 */}
  <div class="reveal flex items-center gap-3" style="--reveal-delay: 0ms">
    <span class="tape-chip tape-chip--solid">NO.001</span>
    <span class="section-eyebrow i18n-zh">个人档案</span>
    <span class="section-eyebrow i18n-en">Personal File</span>
    <span class="h-px flex-1 bg-line max-w-[100px]"></span>
    <span class="font-mono text-xs tracking-[0.25em] text-ink-300">{new Date().getFullYear()}</span>
  </div>

  {/* 主标题 */}
  <h1
    class="reveal display-xl text-[clamp(2.75rem,8vw,6rem)] text-ink-900 mt-6"
    style="--reveal-delay: 120ms"
  >
    <span class="block font-mono font-medium text-[0.22em] tracking-[0.35em] text-ink-700 uppercase mb-4">
      <span class="i18n-zh">你好，我是</span>
      <span class="i18n-en">Hi, I am</span>
    </span>
    <span id="name-type" class="inline-flex items-baseline min-h-[1.05em] rgb-split" aria-live="polite">
      <span id="name-text"></span><span id="name-caret" class="type-caret" aria-hidden="true"></span>
    </span>
  </h1>

  {/* 身份 + 年限 */}
  <div class="reveal mt-10 flex flex-wrap items-baseline gap-x-4 gap-y-2" style="--reveal-delay: 240ms">
    <p class="display-lg text-xl sm:text-2xl text-ink-900">
      <span class="i18n-zh">产品经理</span>
      <span class="i18n-en">Product Manager</span>
    </p>
    <span class="hidden sm:inline h-4 w-px bg-line" aria-hidden="true"></span>
    <p class="text-sm sm:text-base text-ink-700">
      <span class="i18n-zh"><span data-exp-years>2</span> 年互联网产品经验</span>
      <span class="i18n-en"><span data-exp-years>2</span> years in internet products</span>
    </p>
  </div>

  {/* 联系方式 —— 邮箱 + LinkedIn */}
  <div class="reveal mt-8 flex flex-wrap items-center gap-x-8 gap-y-3" style="--reveal-delay: 320ms">
    <a
      href="mailto:linmengfdm@gmail.com"
      class="group inline-flex items-center gap-2.5 text-ink-900 hover:text-brand transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-ink-700 group-hover:text-brand transition-colors">
        <rect x="3" y="5" width="18" height="14" rx="2" />
        <path d="m3 7 9 6 9-6" />
      </svg>
      <span class="text-xs tracking-[0.22em] text-ink-700 group-hover:text-brand font-medium">EMAIL</span>
      <span class="text-base sm:text-lg font-medium tracking-tight">linmengfdm@gmail.com</span>
    </a>
    <span class="hidden sm:inline h-5 w-px bg-line" aria-hidden="true"></span>
    <a
      href="https://www.linkedin.com/in/aaron-wen-60505b2a3/"
      target="_blank"
      rel="noopener noreferrer"
      class="group inline-flex items-center gap-2.5 text-ink-900 hover:text-brand transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-ink-700 group-hover:text-brand transition-colors">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span class="text-xs tracking-[0.22em] text-ink-700 group-hover:text-brand font-medium">LINKEDIN</span>
      <span class="text-base sm:text-lg font-medium tracking-tight">aaron-wen</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="opacity-60 group-hover:opacity-100">
        <path d="M7 17 17 7M9 7h8v8"/>
      </svg>
    </a>
  </div>

  {/* 快捷索引条 */}
  <div class="reveal mt-14 flex items-center gap-5 text-sm" style="--reveal-delay: 440ms">
    <a href="#education" class="group flex items-center gap-2 text-ink-900 hover:text-brand transition-colors font-medium">
      <span class="text-sm text-ink-500 group-hover:text-brand tabular-nums">01</span>
      <span class="i18n-zh">教育</span>
      <span class="i18n-en">Education</span>
    </a>
    <span class="h-px w-6 bg-line"></span>
    <a href="#experience" class="group flex items-center gap-2 text-ink-900 hover:text-brand transition-colors font-medium">
      <span class="text-sm text-ink-500 group-hover:text-brand tabular-nums">02</span>
      <span class="i18n-zh">经历</span>
      <span class="i18n-en">Experience</span>
    </a>
    <span class="h-px w-6 bg-line"></span>
    <a href="#work" class="group flex items-center gap-2 text-ink-900 hover:text-brand transition-colors font-medium">
      <span class="text-sm text-ink-500 group-hover:text-brand tabular-nums">03</span>
      <span class="i18n-zh">项目</span>
      <span class="i18n-en">Work</span>
    </a>
  </div>

  {/* 向下滚动提示 */}
  <div class="reveal mt-20 flex items-center gap-3 text-ink-500 text-xs tracking-widest" style="--reveal-delay: 560ms">
    <span class="inline-block w-8 h-px bg-ink-500"></span>
    <span>SCROLL</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 5v14m-6-6 6 6 6-6"/>
    </svg>
  </div>

  {/* 底部彩条分隔（三原色横条） */}
  <div class="reveal mt-16 color-bars-h" style="--reveal-delay: 680ms" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
</section>

{/* 手写签名 W 模板 */}
<template id="sign-w-template">
  <svg class="sign-w-svg" viewBox="0 0 64 56" aria-hidden="true" preserveAspectRatio="xMidYMid meet">
    <path
      d="M3 6 C 5 18, 10 36, 16 50 C 18 52, 20 52, 22 49 C 25 41, 28 30, 31 20 C 32 17, 34 17, 35 20 C 38 30, 41 41, 44 49 C 46 52, 48 52, 50 50 C 56 36, 60 18, 62 6"
      stroke-width="5.5"
    />
  </svg>
</template>

<script is:inline>
  // ============================================================
  // Experience years · 按入行时间（2024-07-01）自动四舍五入
  // ============================================================
  (function () {
    var start = new Date(2024, 6, 1); // 2024-07-01（月份是 0 索引）
    var now = new Date();
    var months =
      (now.getFullYear() - start.getFullYear()) * 12 +
      (now.getMonth() - start.getMonth());
    var years = Math.max(1, Math.round(months / 12));
    document.querySelectorAll('[data-exp-years]').forEach(function (el) {
      el.textContent = String(years);
    });
  })();
</script>

<script is:inline>
  // ============================================================
  // Hero · 姓名打字状态机 + 手写 W（无手电筒）
  // ============================================================
  (function () {
    const el = document.getElementById('name-text');
    const caret = document.getElementById('name-caret');
    const tpl = document.getElementById('sign-w-template');
    if (!el || !caret || !tpl) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) {
      el.textContent = 'Aaron Wen';
      caret.remove();
      return;
    }

    const sleep = (ms) => new Promise(r => setTimeout(r, ms));

    function setCaret(v) { caret.classList.toggle('is-hidden', !v); }

    function makeSignW() {
      const node = tpl.content.firstElementChild.cloneNode(true);
      const path = node.querySelector('path');
      // 临时挂载以读取 path 长度
      document.body.appendChild(node);
      const len = path.getTotalLength();
      node.remove();
      node.style.setProperty('--len', len.toFixed(1));
      return node;
    }

    // 节奏
    const START_DELAY = 900;
    const TYPE = 78;
    const DEL = 36;
    const HOLD_FULL = 1400;
    const HOLD_EMPTY = 220;
    const SIGN_WRITE_MS = 900;
    const SIGN_HOLD_MS = 1600;
    const SIGN_ERASE_MS = 640;

    async function typePlain(str) {
      for (let i = 1; i <= str.length; i++) {
        el.textContent = str.slice(0, i);
        await sleep(TYPE);
      }
    }
    async function delPlain(str) {
      for (let i = str.length - 1; i >= 0; i--) {
        el.textContent = str.slice(0, i);
        await sleep(DEL);
      }
    }

    async function typeAstroW() {
      await typePlain('Astro');
      await sleep(220);
      setCaret(false);

      const wrap = makeSignW();
      el.appendChild(wrap);
      void wrap.getBoundingClientRect();
      wrap.classList.add('is-writing');
      await sleep(SIGN_WRITE_MS);

      await sleep(SIGN_HOLD_MS);

      wrap.classList.remove('is-writing');
      wrap.classList.add('is-erasing');
      await sleep(SIGN_ERASE_MS);

      wrap.remove();
      setCaret(true);
      await sleep(180);

      await delPlain('Astro');
      await sleep(HOLD_EMPTY);
    }

    async function typeName(str) {
      await typePlain(str);
      await sleep(HOLD_FULL);
      await delPlain(str);
      await sleep(HOLD_EMPTY);
    }

    const sequence = [
      () => typeName('Aaron Wen'),
      () => typeName('温思源'),
      () => typeAstroW(),
    ];

    (async function loop() {
      await sleep(START_DELAY);
      let i = 0;
      while (true) {
        await sequence[i]();
        i = (i + 1) % sequence.length;
      }
    })();
  })();
</script>
