---
import type { CollectionEntry } from 'astro:content';
import LogoPlaceholder from './LogoPlaceholder.astro';

interface Props {
  entry: CollectionEntry<'timeline'>;
  index?: number;
  /** 展示用的编号（NO.xxx），不设则用 index+1 */
  number?: number;
  defaultOpen?: boolean;
}

const { entry, index = 0, number, defaultOpen = false } = Astro.props;
const { Content } = await entry.render();
const {
  org, orgShort, orgZh, orgEn, logo, tint,
  role, roleEn, team, teamEn,
  start, end, location, locationZh, tags, current, kind,
  articles,
} = entry.data;

// 日期：英文 "MAR 2026" / 中文 "2026 年 3 月"
const enFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' });
const startEn = enFmt.format(start).toUpperCase();
const endEn = end ? enFmt.format(end).toUpperCase() : null;
const startZh = `${start.getFullYear()} 年 ${start.getMonth() + 1} 月`;
const endZh = end ? `${end.getFullYear()} 年 ${end.getMonth() + 1} 月` : null;

// 入场延迟
const revealDelay = `${index * 90}ms`;

// 文字 Logo fallback（给 LogoPlaceholder 取首字母用）
const displayName = orgShort || org;

// 处理 articles 封面图：相对路径加 BASE_URL
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
function resolveCover(src?: string): string | undefined {
  if (!src) return undefined;
  if (src.startsWith('http')) return src;
  return `${base}${src.startsWith('/') ? '' : '/'}${src}`;
}
---

<article
  class="reveal card-expandable group relative"
  style={`--reveal-delay: ${revealDelay}`}
  data-expanded={defaultOpen ? 'true' : 'false'}
>
  <div
    class="relative bg-paper-card border border-line transition-colors duration-150
           hover:border-brand"
  >
    {/* 左上编号胶条（孤星风：border-left 橙条 + 实底） */}
    <div class="absolute -top-px left-6 tape-chip z-10">
      NO.{String(number ?? index + 1).padStart(3, '0')}
    </div>

    {/* 折叠态触发区（整个头部可点） */}
    <button
      type="button"
      class="card-trigger block w-full p-6 sm:p-7 pt-10 sm:pt-11"
      aria-expanded={defaultOpen ? 'true' : 'false'}
    >
      <div class="flex items-start gap-4 sm:gap-5">
        {/* Logo */}
        <LogoPlaceholder logo={logo} name={displayName} tint={tint} size={72} />

        {/* 主元信息 */}
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div class="min-w-0">
              {/* 公司名 —— 中英分离，加大字号醒目 */}
              <div class="font-display font-black text-xl sm:text-2xl text-ink-900 leading-tight tracking-tight group-hover:text-brand transition-colors">
                <span class="i18n-zh">{orgZh ?? org}</span>
                <span class="i18n-en">{orgEn ?? org}</span>
              </div>
              {/* 职位 */}
              <div class="mt-1.5 text-base sm:text-lg text-ink-700">
                <span class="i18n-zh">{role}</span>
                <span class="i18n-en">{roleEn ?? role}</span>
                {team && (
                  <span class="text-ink-500">
                    <span class="mx-1.5">·</span>
                    <span class="i18n-zh">{team}</span>
                    <span class="i18n-en">{teamEn ?? team}</span>
                  </span>
                )}
              </div>
            </div>

            {/* 状态徽标 */}
            <div class="flex items-center gap-2 shrink-0 pt-0.5">
              {current && (
                <span class="relative flex h-2 w-2" aria-hidden="true">
                  <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
                </span>
              )}
              <span class:list={[
                'text-xs tracking-[0.2em] font-semibold',
                current ? 'text-brand' : 'text-ink-500',
              ]}>
                {current ? (
                  <>
                    <span class="i18n-zh">进行中</span>
                    <span class="i18n-en">CURRENT</span>
                  </>
                ) : (
                  <span>{end ? end.getFullYear() : start.getFullYear()}</span>
                )}
              </span>
            </div>
          </div>

          {/* 时间 + 地点 */}
          <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-ink-500">
            <span class="tracking-wide tabular-nums">
              {/* 中文时间 */}
              <span class="i18n-zh">
                <span class="text-ink-700">{startZh}</span>
                <span class="mx-1.5">→</span>
                <span class={current ? 'text-brand font-semibold' : 'text-ink-700'}>
                  {current ? '至今' : endZh}
                </span>
              </span>
              {/* 英文时间 */}
              <span class="i18n-en">
                <span class="text-ink-700">{startEn}</span>
                <span class="mx-1.5">→</span>
                <span class={current ? 'text-brand font-semibold' : 'text-ink-700'}>
                  {current ? 'PRESENT' : endEn}
                </span>
              </span>
            </span>
            {(location || locationZh) && (
              <span class="tracking-wide">
                <span class="text-accent">◉</span>{' '}
                <span class="i18n-zh">{locationZh ?? location}</span>
                <span class="i18n-en">{location ?? locationZh}</span>
              </span>
            )}
          </div>
        </div>

        {/* +/− 按钮 */}
        <span class="plus-toggle mt-1" aria-hidden="true"></span>
      </div>
    </button>

    {/* 展开体 */}
    <div class="card-body-wrap">
      <div class="card-body-inner">
        <div class="px-6 sm:px-7 pb-6 sm:pb-7 pt-1 border-t border-line-soft">
          {/* 分隔线 + section eyebrow */}
          <div class="mt-4 mb-3 flex items-center gap-3">
            <span class="h-0.5 w-6 bg-brand"></span>
            <span class="section-eyebrow">
              {kind === 'work' ? (
                <>
                  <span class="i18n-zh">核心产出</span>
                  <span class="i18n-en">Key Contributions</span>
                </>
              ) : (
                <>
                  <span class="i18n-zh">概览</span>
                  <span class="i18n-en">Overview</span>
                </>
              )}
            </span>
          </div>

          {/* 自动编号段落 */}
          <div class="experience-body max-w-none">
            <Content />
          </div>

          {/* 相关报道 / 作品集（China Daily 等） */}
          {articles && articles.length > 0 && (
            <div class="mt-6">
              <div class="mb-3 flex items-center gap-3">
                <span class="h-0.5 w-6 bg-brand"></span>
                <span class="section-eyebrow">
                  <span class="i18n-zh">相关报道</span>
                  <span class="i18n-en">Selected Coverage</span>
                </span>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                {articles.map((a) => {
                  const coverUrl = resolveCover(a.cover);
                  return (
                    <a
                      href={a.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="article-card group block border border-line hover:border-brand transition-colors duration-150 bg-paper-edge/40"
                    >
                      {coverUrl ? (
                        <div class="article-cover">
                          <img src={coverUrl} alt={a.titleEn ?? a.title} loading="lazy" decoding="async" />
                        </div>
                      ) : (
                        <div class="article-cover article-cover--placeholder" aria-hidden="true">
                          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="4" y="5" width="16" height="14" rx="1" />
                            <path d="M4 9h16" />
                            <path d="M8 13h5" />
                            <path d="M8 16h8" />
                          </svg>
                        </div>
                      )}
                      <div class="article-meta">
                        {a.date && (
                          <div class="font-mono text-[10.5px] tracking-[0.18em] text-ink-500 mb-1.5 tabular-nums">
                            {a.date}
                          </div>
                        )}
                        <div class="text-sm font-medium leading-snug text-ink-900 group-hover:text-brand transition-colors">
                          <span class="i18n-zh">{a.title}</span>
                          <span class="i18n-en">{a.titleEn ?? a.title}</span>
                        </div>
                        <div class="mt-2 flex items-center gap-1.5 text-[10.5px] tracking-[0.22em] text-ink-500 group-hover:text-brand transition-colors">
                          <span class="i18n-zh">阅读原文</span>
                          <span class="i18n-en">READ ARTICLE</span>
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path d="M7 17 17 7M9 7h8v8"/>
                          </svg>
                        </div>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          )}

          {/* Tags */}
          {tags.length > 0 && (
            <div class="mt-5 flex flex-wrap gap-1.5">
              {tags.map((t) => (
                <span class="font-mono text-[11px] tracking-wide text-ink-500 border border-line-soft
                             px-2 py-0.5 bg-paper/50">
                  {t}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  /* ==================================================================
     .experience-body —— Markdown 段落自动编号（深色主题）
     ================================================================== */
  .experience-body {
    counter-reset: contribution;
  }

  .experience-body :global(p) {
    counter-increment: contribution;
    position: relative;
    padding-left: 3rem;
    margin: 0.85rem 0;
    color: #B8BEC2;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .experience-body :global(p)::before {
    content: counter(contribution, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 0.2rem;
    font-family: 'Inter', -apple-system, 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #626A70;
    width: 2.4rem;
    border-bottom: 1px solid #2A2F33;
    padding-bottom: 0.15rem;
    transition: color 150ms, border-color 150ms;
  }

  .experience-body :global(p:hover)::before {
    color: #FF5A3C;
    border-bottom-color: #FF5A3C;
  }

  .experience-body :global(strong) {
    color: #EFE6D3;
    font-weight: 700;
  }

  .experience-body :global(a) {
    color: #FF5A3C;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 90, 60, 0.4);
    transition: border-color 150ms;
  }

  .experience-body :global(a:hover) {
    border-bottom-color: #FF5A3C;
  }

  /* ==================================================================
     .article-card —— 展开区的相关报道卡
     ================================================================== */
  .article-card {
    display: block;
    text-decoration: none;
  }
  .article-cover {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0B0D0E;
    border-bottom: 1px solid #1F2326;
    position: relative;
  }
  .article-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms var(--ease-out-expo);
  }
  .article-card:hover .article-cover img {
    transform: scale(1.04);
  }
  .article-cover--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3F464B;
    background:
      repeating-linear-gradient(
        45deg,
        transparent 0 6px,
        rgba(255, 255, 255, 0.015) 6px 7px
      ),
      #0B0D0E;
  }
  .article-meta {
    padding: 0.75rem 0.9rem 0.95rem;
  }
</style>
