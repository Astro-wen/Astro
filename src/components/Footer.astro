---
import { SITE } from '@/lib/site';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-line">
  <div class="container-wide py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm">
    <div class="flex items-center gap-3">
      <span class="font-mono text-xs text-ink-500 tracking-widest">© {year}</span>
      <span class="font-sans font-bold text-ink-900 i18n-zh">{SITE.nameZh}</span>
      <span class="font-sans font-bold text-ink-900 i18n-en">{SITE.name}</span>
    </div>
    <div class="flex items-center gap-4 text-ink-700">
      <SocialLinks />
    </div>
  </div>
</footer>
