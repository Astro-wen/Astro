---
import { SITE } from '@/lib/site';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-line">
  <div class="container-wide py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-ink-500">
      <span class="tabular-nums">© {year}</span>
      <span class="font-semibold text-ink-900 i18n-zh">{SITE.nameZh}</span>
      <span class="font-semibold text-ink-900 i18n-en">{SITE.name}</span>
      <span class="hidden sm:inline text-ink-500">·</span>
      <span class="i18n-zh text-ink-500">
        由
        <a
          href="https://astro.build/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-700 hover:text-brand transition-colors underline-offset-4 hover:underline"
        >Astro</a>
        构建
      </span>
      <span class="i18n-en text-ink-500">
        Powered by
        <a
          href="https://astro.build/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-700 hover:text-brand transition-colors underline-offset-4 hover:underline"
        >Astro</a>
      </span>
    </div>
    <div class="flex items-center gap-4 text-ink-700">
      <SocialLinks />
    </div>
  </div>
</footer>
