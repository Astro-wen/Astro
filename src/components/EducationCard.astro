---
import type { CollectionEntry } from 'astro:content';
import LogoPlaceholder from './LogoPlaceholder.astro';

interface Props {
  entry: CollectionEntry<'timeline'>;
  index?: number;
}

const { entry, index = 0 } = Astro.props;
const {
  org, orgShort, orgZh, orgEn, logo, tint,
  role, roleEn, taglineZh, degreeLine,
  start, end, location, current,
} = entry.data;

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' });
const startStr = fmt.format(start).toUpperCase();
const endStr = end ? fmt.format(end).toUpperCase() : null;
const revealDelay = `${index * 90}ms`;

const displayName = orgShort || org;
---

<article
  class="reveal group"
  style={`--reveal-delay: ${revealDelay}`}
>
  <div class="relative bg-paper-card border border-line hover:border-line-soft transition-colors duration-150 p-6 sm:p-7">
    <div class="flex items-start gap-4 sm:gap-5">
      <LogoPlaceholder logo={logo} name={displayName} tint={tint} size={56} />

      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-0">
            {/* 学校名 */}
            <div class="font-display text-lg sm:text-xl text-ink-900 leading-tight tracking-tight">
              <span class="i18n-zh">{orgZh ?? org}</span>
              <span class="i18n-en">{orgEn ?? org}</span>
            </div>

            {/* 中文副标（仅中文模式） */}
            {taglineZh && (
              <div class="mt-1 text-sm text-ink-700 i18n-zh">{taglineZh}</div>
            )}
            {!taglineZh && (
              <div class="mt-1 text-sm text-ink-700 i18n-zh">{role}</div>
            )}
            {/* 英文模式 role */}
            <div class="mt-1 text-sm text-ink-700 i18n-en">{roleEn ?? role}</div>

            {/* 学位行：两种模式都显示（英文） */}
            {degreeLine && (
              <div class="mt-1 text-xs sm:text-sm text-ink-500 leading-relaxed">
                {degreeLine}
              </div>
            )}
          </div>

          {/* 状态徽标 */}
          <div class="flex items-center gap-2 shrink-0 pt-0.5">
            {current && (
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="absolute inline-flex h-full w-full rounded-full bg-brand opacity-75 animate-ping"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
              </span>
            )}
            <span class:list={[
              'font-mono text-[11px] tracking-[0.2em]',
              current ? 'text-brand font-bold' : 'text-ink-500',
            ]}>
              {current ? (
                <>
                  <span class="i18n-zh">在读</span>
                  <span class="i18n-en">IN PROGRESS</span>
                </>
              ) : (
                <>
                  <span class="i18n-zh">已毕业</span>
                  <span class="i18n-en">GRADUATED</span>
                </>
              )}
            </span>
          </div>
        </div>

        {/* 时间 + 地点 */}
        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs font-mono text-ink-500">
          <span class="tracking-wider">
            <span class="text-ink-700">{startStr}</span>
            <span class="mx-1.5">→</span>
            <span class={current ? 'text-brand font-bold' : 'text-ink-700'}>
              {current ? (
                <>
                  <span class="i18n-zh">至今</span>
                  <span class="i18n-en">PRESENT</span>
                </>
              ) : endStr}
            </span>
          </span>
          {location && (
            <span class="tracking-wide">
              <span class="text-accent">◉</span> {location}
            </span>
          )}
        </div>
      </div>
    </div>
  </div>
</article>
