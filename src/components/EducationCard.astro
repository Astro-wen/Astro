---
import type { CollectionEntry } from 'astro:content';
import LogoPlaceholder from './LogoPlaceholder.astro';

interface Props {
  entry: CollectionEntry<'timeline'>;
  index?: number;
}

const { entry, index = 0 } = Astro.props;
const {
  org, orgShort, orgZh, orgEn, logo, tint, url,
  role, roleEn,
  start, end, location, locationZh, current,
} = entry.data;

// 日期：英文用 "SEP 2024" 这种，中文用 "2024 年 9 月"
const enFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' });
const startEn = enFmt.format(start).toUpperCase();
const endEn = end ? enFmt.format(end).toUpperCase() : null;
const startZh = `${start.getFullYear()} 年 ${start.getMonth() + 1} 月`;
const endZh = end ? `${end.getFullYear()} 年 ${end.getMonth() + 1} 月` : null;
const revealDelay = `${index * 90}ms`;

const displayName = orgShort || org;

// 整卡是否可点击：有 url 则包成 <a>
const Wrapper = url ? 'a' : 'div';
const wrapperProps = url
  ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<article
  class="reveal group"
  style={`--reveal-delay: ${revealDelay}`}
>
  <Wrapper
    {...wrapperProps}
    class:list={[
      'block relative bg-paper-card border border-line transition-colors duration-150 p-7 sm:p-8',
      url ? 'hover:border-brand cursor-pointer' : 'hover:border-line-soft',
    ]}
  >
    <div class="flex items-start gap-5 sm:gap-6">
      <LogoPlaceholder logo={logo} name={displayName} tint={tint} size={72} />

      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-0 flex-1">
            {/* 学校名 —— 加大字号，醒目 */}
            <div class:list={[
              'font-display text-xl sm:text-2xl md:text-[1.75rem] text-ink-900 leading-tight tracking-tight',
              url ? 'group-hover:text-brand transition-colors' : '',
            ]}>
              <span class="i18n-zh">{orgZh ?? org}</span>
              <span class="i18n-en">{orgEn ?? org}</span>
            </div>

            {/* 学位描述 —— 加大字号 */}
            <div class="mt-2 text-sm sm:text-base text-ink-700 leading-relaxed">
              <span class="i18n-zh">{role}</span>
              <span class="i18n-en">{roleEn ?? role}</span>
            </div>
          </div>

          {/* 状态徽标 */}
          <div class="flex items-center gap-2 shrink-0 pt-1">
            {current && (
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
              </span>
            )}
            <span class:list={[
              'text-xs tracking-[0.2em] font-semibold',
              current ? 'text-brand' : 'text-ink-500',
            ]}>
              {current ? (
                <>
                  <span class="i18n-zh">在读</span>
                  <span class="i18n-en">IN PROGRESS</span>
                </>
              ) : (
                <>
                  <span class="i18n-zh">已毕业</span>
                  <span class="i18n-en">GRADUATED</span>
                </>
              )}
            </span>

            {/* 有外链时显示一个外链图标 */}
            {url && (
              <svg
                width="14" height="14" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2.5"
                aria-hidden="true"
                class="ml-1 text-ink-500 group-hover:text-brand transition-colors"
              >
                <path d="M7 17 17 7M9 7h8v8"/>
              </svg>
            )}
          </div>
        </div>

        {/* 时间 + 地点 */}
        <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-ink-500">
          <span class="tracking-wide tabular-nums">
            {/* 中文时间 */}
            <span class="i18n-zh">
              <span class="text-ink-700">{startZh}</span>
              <span class="mx-1.5">→</span>
              <span class={current ? 'text-brand font-semibold' : 'text-ink-700'}>
                {current ? '至今' : endZh}
              </span>
            </span>
            {/* 英文时间 */}
            <span class="i18n-en">
              <span class="text-ink-700">{startEn}</span>
              <span class="mx-1.5">→</span>
              <span class={current ? 'text-brand font-semibold' : 'text-ink-700'}>
                {current ? 'PRESENT' : endEn}
              </span>
            </span>
          </span>
          {(location || locationZh) && (
            <span class="tracking-wide">
              <span class="text-accent">◉</span>{' '}
              <span class="i18n-zh">{locationZh ?? location}</span>
              <span class="i18n-en">{location ?? locationZh}</span>
            </span>
          )}
        </div>
      </div>
    </div>
  </Wrapper>
</article>
