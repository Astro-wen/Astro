---
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
}
const { project, index = 0 } = Astro.props;
const { name, summary, stack, url, repo } = project.data;

// VHS 三原色索引色标（按 index % 3 轮换） —— 左侧 4px 装饰
const vhsColors = ['#29D2C8', '#F4C341', '#E8483D'];
const barColor = vhsColors[index % 3];
---

<article
  class="group relative bg-paper-card border border-line pl-6 sm:pl-7 pr-5 sm:pr-6 py-5 sm:py-6
         hover:border-brand transition-colors duration-150"
>
  {/* 左侧 VHS 索引色标（4px） */}
  <span
    class="absolute top-0 bottom-0 left-0 w-1 pointer-events-none"
    style={`background: ${barColor};`}
    aria-hidden="true"
  ></span>

  <div class="flex items-start justify-between gap-3">
    <h3 class="font-sans font-black text-lg text-ink-900 group-hover:text-brand transition-colors">
      {name}
    </h3>
    <div class="flex items-center gap-2 shrink-0 text-ink-700">
      {repo && (
        <a href={repo} target="_blank" rel="noopener noreferrer" aria-label="Repository" class="hover:text-brand transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.47.11-3.06 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.9-.39.99 0 1.98.13 2.9.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.77.11 3.06.73.8 1.18 1.83 1.18 3.09 0 4.43-2.71 5.41-5.29 5.69.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .31.21.68.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.73 18.27.5 12 .5z"/></svg>
        </a>
      )}
      {url && (
        <a href={url} target="_blank" rel="noopener noreferrer" aria-label="Live site" class="hover:text-brand transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17 17 7" /><path d="M8 7h9v9" />
          </svg>
        </a>
      )}
    </div>
  </div>
  <p class="mt-2 text-sm sm:text-base text-ink-700 leading-relaxed">
    {summary}
  </p>
  {stack.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {stack.map((s) => <Tag label={s} />)}
    </div>
  )}
</article>
