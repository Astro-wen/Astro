---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import Tag from '@/components/Tag.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// 统计 tag 频次
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const t of post.data.tags) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Blog" description="文章列表">
  <section class="container-prose py-12 sm:py-16">
    <h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight text-ink-900">Blog</h1>
    <p class="mt-3 text-ink-700">记录想法、笔记与折腾过程。</p>

    {tags.length > 0 && (
      <div class="mt-6 flex flex-wrap gap-1.5">
        {tags.map(([t, count]) => (
          <Tag label={`${t} · ${count}`} />
        ))}
      </div>
    )}

    <div class="mt-8">
      {allPosts.length === 0 ? (
        <p class="text-ink-500">还没有文章，稍后再来吧。</p>
      ) : (
        allPosts.map((post) => <PostCard post={post} />)
      )}
    </div>
  </section>
</BaseLayout>
