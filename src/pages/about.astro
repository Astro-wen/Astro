---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { SITE } from '@/lib/site';

const skills = [
  {
    group: '产品',
    groupEn: 'Product',
    items: [
      'PRD 撰写', 'Post-Mortems', '竞品分析', '用户研究', 'Roadmapping',
      'AI-native PM 工作流（Claude Code / Cursor / MCP）',
      'Figma · Jira · Linear · Asana · Notion · Miro · Slack',
    ],
  },
  {
    group: '分析',
    groupEn: 'Analytics',
    items: [
      'SQL', 'Python (Pandas / Scikit-learn / PyTorch)', 'R',
      'Tableau', 'Excel', 'A/B Testing', '漏斗分析',
    ],
  },
  {
    group: '游戏',
    groupEn: 'Games',
    items: [
      'Mobile Game KPIs (DAU / ARPU / Retention / Conversion)',
      'Live-Ops Design', 'Event & Offer Design', 'Quest Design',
      'Game Economy Modeling', 'Player Segmentation',
      'Agile', 'Unity · Godot · UE5',
    ],
  },
];
---

<BaseLayout title="关于" description={`关于 ${SITE.name}`}>
  <section class="container-wide py-16 sm:py-24">
    <SectionHeader
      index="§"
      title="温思源 · Aaron Wen"
      tag="About"
      subtitle="产品经理"
      subtitleEn="Product Manager"
    />

    <div class="grid grid-cols-12 gap-6 lg:gap-10">
      <div class="col-span-12 lg:col-span-8">
        <div class="reveal prose prose-invert max-w-none i18n-zh" style="--reveal-delay: 80ms">
          <p>
            大家好，我是 <strong>温思源（Aaron Wen）</strong>，代号 <span class="metric">AstroW</span>。
            目前在 <strong>UCLA</strong> 读统计与数据科学 + 商业经济学双学位，专注游戏、AI 原生产品与玩家增长。
          </p>
          <p>
            过去在 <strong>TikTok（Account Center · Infra）</strong>、
            <strong>Tencent America（IEGG）</strong> 和 <strong>Tencent Games（研发效能部）</strong>
            做过产品实习，涉及多账号基础设施、AI 能力聚合平台、手游 AI 战斗伙伴、游戏化系统、上线活动策略等方向。
          </p>
          <p>
            我相信好产品是"<strong>把复杂系统变得一目了然</strong>"这件事的结果——
            在定义之前先把用户和系统都看懂，然后用最少的概念把事情讲清楚。
          </p>
          <p>
            想聊聊的话，可以通过
            <a href={SITE.social.email}>邮件</a>
            或
            <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            联系我。
          </p>
        </div>

        <div class="reveal prose prose-invert max-w-none i18n-en" style="--reveal-delay: 80ms">
          <p>
            Hi, I'm <strong>Aaron Wen (温思源)</strong>, codename <span class="metric">AstroW</span>.
            I'm a dual-degree student at <strong>UCLA</strong> in Statistics &amp; Data Science and Business Economics, focused on games, AI-native products, and player growth.
          </p>
          <p>
            Previously I interned as a PM at <strong>TikTok (Account Center · Infra)</strong>,
            <strong>Tencent America (IEGG)</strong>, and <strong>Tencent Games (R&amp;D Efficiency)</strong> — working on multi-account infrastructure, AI capability platforms, mobile-game AI combat companions, gamification, and launch live-ops.
          </p>
          <p>
            I believe great products are the result of one thing: <strong>making complex systems feel obvious</strong>. Understand the user and the system before defining anything, then explain it with the fewest concepts possible.
          </p>
          <p>
            Want to chat? Reach me by
            <a href={SITE.social.email}>email</a> or
            <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>.
          </p>
        </div>
      </div>

      <aside class="col-span-12 lg:col-span-4">
        <div class="reveal sticky top-24 space-y-6" style="--reveal-delay: 160ms">
          <div class="border border-line bg-paper-card p-5">
            <div class="section-eyebrow mb-3">
              <span class="i18n-zh">联系</span>
              <span class="i18n-en">Contact</span>
            </div>
            <dl class="space-y-2 text-sm">
              <div class="flex items-baseline gap-3">
                <dt class="font-mono text-xs text-ink-500 w-14 shrink-0">EMAIL</dt>
                <dd class="text-ink-900">
                  <a href={SITE.social.email} class="hover:text-brand transition-colors">linmengfdm@gmail.com</a>
                </dd>
              </div>
              <div class="flex items-baseline gap-3">
                <dt class="font-mono text-xs text-ink-500 w-14 shrink-0">LOC</dt>
                <dd class="text-ink-700">Los Angeles / San Jose</dd>
              </div>
              <div class="flex items-baseline gap-3">
                <dt class="font-mono text-xs text-ink-500 w-14 shrink-0">STATUS</dt>
                <dd class="text-brand font-bold flex items-center gap-1.5">
                  <span class="inline-flex h-2 w-2 rounded-full bg-brand"></span>
                  <span class="i18n-zh">寻找 2026 年实习</span>
                  <span class="i18n-en">Open to 2026 Intern</span>
                </dd>
              </div>
            </dl>
          </div>
        </div>
      </aside>
    </div>

    {/* 技能矩阵 */}
    <div class="mt-20">
      <SectionHeader
        index="02"
        title="技能矩阵"
        tag="Stack"
        delay={120}
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-5">
        {skills.map((group, i) => (
          <div
            class="reveal border border-line bg-paper-card p-5 sm:p-6
                   hover:border-brand transition-colors duration-150"
            style={`--reveal-delay: ${200 + i * 90}ms`}
          >
            <div class="flex items-center gap-2 mb-4">
              <span class="font-display text-brand text-2xl leading-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-sans font-black text-ink-900 i18n-zh">{group.group}</span>
              <span class="font-sans font-black text-ink-900 i18n-en">{group.groupEn}</span>
            </div>
            <ul class="space-y-1.5 text-sm text-ink-700">
              {group.items.map((it) => (
                <li class="flex items-baseline gap-2">
                  <span class="text-ink-500 font-mono text-xs">—</span>
                  <span>{it}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
